# Global working directory fallback for all panels and startup commands (optional)
workingdir = "."

# Commands to run sequentially in the background when the TUI starts.
# Their output is streamed to the Message Buffer (view with Ctrl-B).
[[startup]]
program = "sleep"
args = ["2"]
workingdir = "." # optional: defaults to the global 'workingdir', then to muxedo's launch directory

[[startup]]
shell = "printf 'warming up demo services\\n'; sleep 3"

[panel.pong]
shell = "i=0 d=1; while true; do printf '\\r[%*s><%*s]' \"$i\" '' \"$((20-i))\" ''; sleep 0.08; [ \"$i\" -eq 20 ] && d=-1; [ \"$i\" -eq 0 ] && d=1; i=$((i+d)); done"

[panel.processes]
shell = "while true; do ps -eo pid,comm,%cpu,%mem --sort=-%cpu | head -n 8; sleep 5; done"

[panel.metrics]
shell = "while true; do printf 'loadavg '; cut -d ' ' -f1-3 /proc/loadavg; printf 'memavail '; grep MemAvailable /proc/meminfo; sleep 10; done"

[panel.echo]
shell = "printf 'Insert mode demo: type something and press Enter.\\n\\n'; while IFS= read -r line; do printf 'you typed: %s\\n' \"$line\"; done"

# Optional [scrollback] — omit this section to use defaults (dir: OS cache / muxedo / scrollback; max_bytes: 1 MiB per panel)
# [scrollback]
# dir = "~/.cache/muxedo/scrollback"   # log file directory (~ expanded)
# max_bytes = 1048576                  # per-panel cap in bytes; 0 = unlimited
